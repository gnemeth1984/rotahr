generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       User[]
  departments Department[]
  employees   Employee[]
  tables      Table[]
  reservations Reservation[]
  expenses    Expense[]
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  password   String?
  role       String   @default("STAFF")
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employees  Employee[]
}

model Department {
  id         String   @id @default(cuid())
  name       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employees  Employee[]
}

model Employee {
  id           String  @id @default(cuid())
  firstName    String
  lastName     String
  email        String  @unique
  phone        String?
  ppsNumber    String?
  role         String  @default("staff")
  active       Boolean @default(true)
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  userId       String?
  user         User?   @relation(fields: [userId], references: [id])

  // Emergency contact
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?

  // Medical info
  medicalConditions String?   // allergies, chronic conditions
  medications       String?   // current medications
  bloodType         String?   // A+, B-, O+, etc.
  doctorName        String?
  doctorPhone       String?
  medicalNotes      String?   // any other relevant info

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shifts          Shift[]
  timeOffRequests TimeOffRequest[]
  expenses        Expense[]
  notifications   BookingNotification[]
  flags           BookingFlag[]
}

model Shift {
  id            String    @id @default(cuid())
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  role          String?
  published     Boolean   @default(false)
  overtimeHours Float     @default(0)
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TimeOffRequest {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending")
  reason      String?
  managedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Table {
  id         String   @id @default(cuid())
  name       String
  capacity   Int
  location   String?
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reservations Reservation[]
}

model Expense {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id])

  // Core fields
  amount        Float
  vatAmount     Float     @default(0)
  currency      String    @default("EUR")
  vendor        String?
  category      String    // wages, supplier, utilities, equipment, food_beverage, general
  date          DateTime
  description   String?
  paymentMethod String?   // cash, card, bank_transfer
  status        String    @default("confirmed") // draft, confirmed

  // Receipt image
  receiptUrl    String?
  aiRawText     String?   // raw AI extraction output

  // Optional employee link (for staff cost expenses)
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])

  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Reservation {
  id           String   @id @default(cuid())
  customerName String
  customerEmail String?
  customerPhone String?
  partySize    Int
  date         DateTime
  time         String
  duration     Int      @default(90)
  status       String   @default("confirmed")
  notes        String?
  dietary      String?
  occasion     String?
  kitchenNotes String?
  upsellNotes  String?
  aiWarnings   String?
  createdById  String?
  tableId      String?
  table        Table?   @relation(fields: [tableId], references: [id])
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notifications BookingNotification[]
  flags         BookingFlag[]
}

// Notification sent to a specific employee about a booking
model BookingNotification {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  message       String?     // optional note from manager
  read          Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

// Employee flags a booking with a note for management
model BookingFlag {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  note          String
  resolved      Boolean     @default(false)
  createdAt     DateTime    @default(now())
}
