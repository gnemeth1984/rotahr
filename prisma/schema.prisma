generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                 String       @id @default(cuid())
  name               String
  onboardingComplete Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Geofencing for clock in/out
  geoLat             Float?       // premises latitude
  geoLng             Float?       // premises longitude
  geoRadius          Int          @default(200) // metres

  // Labour cost / revenue target (used in rota live cost banner)
  weeklyRevenueTarget Float?      // manager-set revenue target for current week
  venues              Venue[]

  users        User[]
  departments  Department[]
  employees    Employee[]
  tables       Table[]
  reservations Reservation[]
  expenses     Expense[]
  menuSpecials MenuSpecial[]
  aiSettings   AISettings?
  suppliers    Supplier[]
  stockItems   StockItem[]
  supplierOrders SupplierOrder[]
  supplierStatements SupplierStatement[]
  shiftSwapRequests ShiftSwapRequest[]
  tipPools     TipPool[]
  dishes       Dish[]
  weeklyMenuPlans WeeklyMenuPlan[]
  menuTemplates   MenuTemplate[]
  functionMenus   FunctionMenu[]

  // POS Integration
  posConnection  PosConnection?
  posSnapshots   PosSnapshot[]

  // CRM
  customers      Customer[]

  // Wastage
  wastageRecords WastageRecord[]

  // HACCP
  haccpRecords   HACCPRecord[]

  // Locale / currency
  currency           String   @default("EUR") // "EUR" | "GBP"
  country            String   @default("IE")  // "IE" | "GB"

  // Feature flags — controls which modules are enabled and who can see them
  // Stored as JSON: { [featureKey]: { enabled: boolean, roles: string[] } }
  // roles = subset of ["EMPLOYEE","MANAGER","ADMIN"] — who can SEE this feature
  featureFlags       Json?     // null = all features on with default roles

  // Lemon Squeezy subscription
  lsCustomerId       String?   // Lemon Squeezy customer ID
  lsSubscriptionId   String?   // Lemon Squeezy subscription ID
  lsVariantId        String?   // active variant ID
  lsPlan             String?   @default("none") // "none" | "starter" | "pro" | "enterprise"
  lsStatus           String?   @default("none") // "active" | "cancelled" | "past_due" | "none"
  lsRenewsAt         DateTime?
  lsEndsAt           DateTime?
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  password   String?
  role       String    @default("STAFF")
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  pushSubscription    String?   // Web Push subscription JSON

  employees           Employee[]
  passwordResetTokens PasswordResetToken[]
  appNotifications    AppNotification[]
  menuSpecials        MenuSpecial[]     @relation("MenuSpecialAuthor")
  crmNotes            CrmNote[]
  crmEmails           CrmEmail[]
  haccpRecords        HACCPRecord[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id         String   @id @default(cuid())
  name       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?
  role         String   @default("staff")
  hourlyRate   Float?
  active       Boolean  @default(true)
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])

  // HR / Payroll fields
  startDate       DateTime?
  contractType    String?   // full-time | part-time | casual | zero-hours
  address         String?
  nationality     String?
  ppsn            String?   // PPS Number (encrypted at app layer ideally)
  bankIban        String?   // IBAN (sensitive)
  bankBic         String?
  emergencyName   String?
  emergencyPhone  String?
  emergencyRel    String?   // relationship

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts          Shift[]
  timeOffRequests TimeOffRequest[]
  expenses        Expense[]
  notifications   BookingNotification[]
  flags           BookingFlag[]
  clockEvents     ClockEvent[]
  sentMessages    Message[]              @relation("MessageSender")
  receivedMessages Message[]             @relation("MessageRecipient")
  availability    AvailabilityPreference[]
  extraAvailability ExtraAvailability[]
  shiftTemplates  ShiftTemplate[]
  shiftSwapRequestsOffered  ShiftSwapRequest[] @relation("SwapOfferer")
  shiftSwapRequestsReceived ShiftSwapRequest[] @relation("SwapReceiver")
  tipDistributions TipDistribution[]
  certifications   TrainingCertification[]
  venueId          String?
  venue            Venue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)
  permissions      String[] @default([])
  documents        EmployeeDocument[]
  onboardingTasks  OnboardingTask[]
}

model Shift {
  id            String    @id @default(cuid())
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  role          String?
  published     Boolean   @default(false)
  venueId       String?
  venue         Venue?    @relation(fields: [venueId], references: [id], onDelete: SetNull)
  overtimeHours Float     @default(0)
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TimeOffRequest {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending")
  reason      String?
  managedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Table {
  id         String   @id @default(cuid())
  name       String
  capacity   Int
  location   String?
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reservations Reservation[]
}

model Expense {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])

  amount        Float
  vatAmount     Float    @default(0)
  currency      String   @default("EUR")
  vendor        String?
  category      String
  date          DateTime
  description   String?
  paymentMethod String?
  status        String   @default("confirmed")

  receiptUrl      String?
  receiptDataUrl  String?   // base64 data URI — permanent fallback for 30-day recall
  receiptExpiresAt DateTime? // 30 days from upload
  aiRawText       String?
  aiLineItems     Json?     // structured line items extracted by AI: [{name, quantity, unit, unitPrice}]

  // Irish Revenue / VAT compliance fields
  supplierVatNumber String?   // supplier's VAT registration number (required for VAT reclaim)
  legalBasis        String?   @default("legal_obligation") // GDPR Art.6(1)(c) — legal obligation

  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reservation {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  partySize     Int
  date          DateTime
  time          String
  duration      Int      @default(90)
  status        String   @default("confirmed")
  notes         String?
  dietary       String?
  occasion      String?
  menuRequired  Boolean @default(false)
  kitchenNotes  String?
  upsellNotes   String?
  aiWarnings    String?
  createdById   String?
  createdByName     String?
  marketingConsent  Boolean @default(false)
  tableId           String?
  table         Table?   @relation(fields: [tableId], references: [id])
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  notifications BookingNotification[]
  flags         BookingFlag[]
}

model BookingNotification {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  message       String?
  read          Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model BookingFlag {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  note          String
  resolved      Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

// ── Staff Messaging ────────────────────────────────────────────────────────────
model Message {
  id          String   @id @default(cuid())
  businessId  String
  senderId    String
  recipientId String
  body        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender    Employee @relation("MessageSender",    fields: [senderId],    references: [id], onDelete: Cascade)
  recipient Employee @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
}

// ── Clock In / Out ─────────────────────────────────────────────────────────────
model ClockEvent {
  id         String   @id @default(cuid())
  employeeId String
  businessId String
  type       String   // "in" | "out"
  timestamp  DateTime @default(now())
  note       String?
  shiftId    String?
  latitude   Float?   // where employee clocked in/out
  longitude  Float?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ── Staff Availability Preferences ────────────────────────────────────────────
model AvailabilityPreference {
  id         String   @id @default(cuid())
  employeeId String
  businessId String
  dayOfWeek  Int      // 0=Sun 1=Mon … 6=Sat
  available  Boolean  @default(true)
  fromTime   String?  // "09:00"
  toTime     String?  // "17:00"
  note       String?
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
}

// ── Extra Shift Availability (date-specific volunteer board) ──────────────────
model ExtraAvailability {
  id         String   @id @default(cuid())
  employeeId String
  businessId String
  date       DateTime // specific date they're available for extras
  fromTime   String?  // "09:00" optional preferred window
  toTime     String?  // "17:00"
  note       String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([businessId, date])
}

// ── Repeating Shift Templates ──────────────────────────────────────────────────
model ShiftTemplate {
  id           String   @id @default(cuid())
  businessId   String
  employeeId   String?
  dayOfWeek    Int
  startHour    Int
  startMinute  Int      @default(0)
  endHour      Int
  endMinute    Int      @default(0)
  role         String?
  active       Boolean  @default(true)
  templateName String?
  venueId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  venue    Venue?    @relation(fields: [venueId], references: [id], onDelete: SetNull)

  @@index([businessId, templateName])
}

// ── In-App Notifications ───────────────────────────────────────────────────────
model AppNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "message" | "shift" | "timeoff" | "booking" | "rota" | "late_checkin" | "cert_expiry"
  title       String
  body        String
  link        String?
  referenceId String?  // shift/cert/etc ID for dedup
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, read])
}

// ── Menu Specials / Board ──────────────────────────────────────────────────────
model MenuSpecial {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("MenuSpecialAuthor", fields: [createdById], references: [id])

  title       String
  description String?   @db.Text
  category    String    @default("special") // "special" | "change" | "announcement" | "86'd"
  date        DateTime  // primary date / start of range
  endDate     DateTime? // optional end date for multi-day
  pinned      Boolean   @default(false)
  imageUrl    String?   // optional photo of the dish
  imageDataUri String?  @db.Text
  archived    Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([businessId, archived, date])
}

// ── AI Assistant Settings ──────────────────────────────────────────────────────
model AISettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Staffing thresholds
  bookingThresholdForStaffIncrease Int     @default(20)   // covers → suggest more staff
  kitchenRatio                     Int     @default(20)   // 1 kitchen per N covers
  floorRatio                       Int     @default(15)   // 1 floor per N covers
  minBarStaff                      Int     @default(1)

  // Rota settings
  rotaWarningDaysAhead             Int     @default(3)    // warn about short staffing X days ahead
  autoFlagShortStaffedShifts       Boolean @default(true)
  minStaffPerShift                 Int     @default(2)

  // Specials / price change communication
  priceChangeNotifyScope           String  @default("managers") // "managers" | "all_staff" | "none"
  priceChangeMessage               String? @db.Text             // custom message template

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Stock Management ───────────────────────────────────────────────────────────
model Supplier {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?  @db.Text
  active      Boolean  @default(true)

  stockItems  StockItem[]
  orders      SupplierOrder[]
  statements  SupplierStatement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, active])
}

model StockItem {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])

  name         String
  sku          String?          // supplier's product code
  unit         String           @default("unit") // "unit", "kg", "litre", "case", "box", "bottle" etc
  category     String           @default("general") // "food", "beverage", "cleaning", "packaging", "equipment", "other"

  lastPrice    Float?           // price from most recent receipt/invoice
  lastOrdered  DateTime?        // date of last order
  reorderLevel Float?           // trigger reorder below this qty
  currentStock Float?           // optional manual stock count
  notes        String?          @db.Text

  // Source tracing
  lastExpenseId String?         // which expense/receipt last updated this item

  orderItems   OrderItem[]
  dishIngredients DishIngredient[]
  wastageRecords WastageRecord[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId, supplierId])
  @@index([businessId, category])
}

model SupplierOrder {
  id          String      @id @default(cuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier    @relation(fields: [supplierId], references: [id])

  status      String      @default("draft")   // "draft" | "sent" | "received"
  notes       String?     @db.Text
  sentAt      DateTime?
  receivedAt  DateTime?

  items       OrderItem[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([businessId, supplierId, status])
}

model OrderItem {
  id          String        @id @default(cuid())
  orderId     String
  order       SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem     @relation(fields: [stockItemId], references: [id])

  quantity    Float
  unitPrice   Float?
  notes       String?

  @@index([orderId])
}

// ── Shift Swap Marketplace ─────────────────────────────────────────────────────
// Complies with: Organisation of Working Time Act 1997 (rest periods enforced
// in validation before approval), GDPR Art.6(1)(b) performance of contract.
model ShiftSwapRequest {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // The employee offering their shift
  offererId       String
  offerer         Employee @relation("SwapOfferer", fields: [offererId], references: [id], onDelete: Cascade)
  offeredShiftId  String   // Shift the offerer wants to give away

  // The employee accepting (null until someone accepts)
  receiverId      String?
  receiver        Employee? @relation("SwapReceiver", fields: [receiverId], references: [id])
  receiverShiftId String?   // Optional: the receiver's shift to swap (can be open swap)

  status          String   @default("open")
  // "open"      — listed, waiting for taker
  // "pending"   — receiver accepted, awaiting manager approval
  // "approved"  — manager approved, shifts reassigned
  // "rejected"  — manager rejected
  // "cancelled" — offerer withdrew

  managerNote     String?
  managedById     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessId, status])
  @@index([offererId])
}

// ── Tip / Tronc Management ────────────────────────────────────────────────────
// Complies with: Payment of Wages (Amendment) (Tips and Gratuities) Act 2022
// (Irish law — mandatory transparent distribution records)
model TipPool {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  periodStart DateTime  // start of period (typically week start)
  periodEnd   DateTime  // end of period
  totalAmount Float     // total tips collected (€)
  method      String    @default("hours") // "hours" | "equal" | "custom"
  notes       String?   @db.Text
  status      String    @default("draft") // "draft" | "distributed"
  distributedAt DateTime?

  distributions TipDistribution[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, periodStart])
}

model TipDistribution {
  id          String   @id @default(cuid())
  poolId      String
  pool        TipPool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  hoursWorked Float    @default(0)  // hours in the period (used for "hours" method)
  shareAmount Float    // € amount allocated to this employee
  customNote  String?  // reason for custom override

  @@index([poolId])
  @@index([employeeId])
}


// ── Multi-Venue Support ───────────────────────────────────────────────────────
model Venue {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  address     String?
  phone       String?
  email       String?
  website     String?
  geoLat      Float?
  geoLng      Float?
  geoRadius   Int      @default(200)
  timezone    String   @default("Europe/Dublin")
  isDefault   Boolean  @default(false)
  active      Boolean  @default(true)

  // Venue details
  capacity    Int?
  venueType   String?  // restaurant | bar | hotel | cafe | pub | other
  cuisine     String?  // Irish, Italian, etc.
  foodInfo    String?  @db.Text  // food menu notes, allergies policy, dietary options
  drinksInfo  String?  @db.Text  // bar notes, draught lines, house spirits
  equipment   String?  @db.Text  // POS systems, kitchen equipment, A/V notes
  notes       String?  @db.Text  // general manager notes

  employees       Employee[]
  shifts          Shift[]
  shiftTemplates  ShiftTemplate[]
  checklists      VenueChecklist[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

model VenueChecklist {
  id          String   @id @default(cuid())
  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  businessId  String
  title       String
  category    String   @default("general") // opening | closing | cleaning | health-safety | general
  items       VenueChecklistItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([venueId])
  @@index([businessId])
}

model VenueChecklistItem {
  id          String         @id @default(cuid())
  checklistId String
  checklist   VenueChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  label       String
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())

  @@index([checklistId])
}

// ── Page Views / Visitor Analytics ───────────────────────────────────────────
model PageView {
  id        String   @id @default(cuid())
  path      String   // e.g. "/", "/pricing", "/auth/signin"
  referrer  String?  // where they came from
  userAgent String?  @db.Text
  country   String?  // from Vercel geo headers
  city      String?
  sessionId String?  // anonymous session cookie
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
}

// ── Training & Certifications ─────────────────────────────────────────────────
// HACCP, alcohol serving certs, manual handling, first aid — Irish legal requirements
model TrainingCertification {
  id          String   @id @default(cuid())
  businessId  String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  title       String   // e.g. "HACCP Level 2", "RSA Bar Skills"
  issuer      String?  // e.g. "Failte Ireland", "QQI"
  category    String   @default("OTHER") // HACCP | ALCOHOL | MANUAL_HANDLING | FIRST_AID | FOOD_SAFETY | OTHER
  issuedDate  DateTime?
  expiryDate  DateTime?
  documentUrl String?  // Vercel Blob URL
  notes       String?  @db.Text

  // Computed status — set by cron, not stored (derive from expiryDate)
  // VALID = expiryDate > today+30d, EXPIRING_SOON = within 30d, EXPIRED = past, NO_EXPIRY = null expiryDate

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, category])
  @@index([employeeId])
  @@index([expiryDate])
}

// ── Menu Planning ─────────────────────────────────────────────────────────────

model Dish {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?  @db.Text
  category    String   @default("main") // starter | main | dessert | drinks | sides | other
  sellPrice   Float?
  costPrice   Float?   // auto-calculated from ingredients if set
  imageUrl    String?
  active      Boolean  @default(true)

  ingredients DishIngredient[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, active])
}

model DishIngredient {
  id          String    @id @default(cuid())
  dishId      String
  dish        Dish      @relation(fields: [dishId], references: [id], onDelete: Cascade)
  stockItemId String?
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)

  name        String    // free-text fallback if no stockItemId
  qty         Float     @default(1)
  unit        String    @default("unit")

  @@index([dishId])
}

model WeeklyMenuPlan {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  weekStart   DateTime // Monday date (date only, no time)
  planData    Json     // { mon: { breakfast: [dishId,...], lunch: [...], dinner: [...] }, tue: {...}, ... }

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, weekStart])
  @@index([businessId, weekStart])
}

model MenuTemplate {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  planData    Json     // same shape as WeeklyMenuPlan.planData

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

// ── Function Menus ────────────────────────────────────────────────────────────

model FunctionMenu {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String                // e.g. "Wedding Package A"
  description String?  @db.Text
  pricePerHead Float?
  minGuests   Int?
  maxGuests   Int?
  isActive    Boolean  @default(true)
  shareToken  String   @unique @default(cuid()) // for public shareable link

  courses     FunctionMenuCourse[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, isActive])
}

model FunctionMenuCourse {
  id             String       @id @default(cuid())
  functionMenuId String
  functionMenu   FunctionMenu @relation(fields: [functionMenuId], references: [id], onDelete: Cascade)

  courseType     String       // starter | soup | main | dessert | cheese | tea_coffee | canapes | kids | buffet
  label          String?      // custom label override e.g. "Amuse Bouche"
  choiceCount    Int          @default(1)  // "Choose X from below"
  sortOrder      Int          @default(0)

  dishes         FunctionMenuDish[]

  @@index([functionMenuId, sortOrder])
}

model FunctionMenuDish {
  id       String             @id @default(cuid())
  courseId String
  course   FunctionMenuCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  name        String
  description String?  @db.Text
  notes       String?  @db.Text  // staff notes

  // Dietary badges
  isVegan        Boolean @default(false)
  isVegetarian   Boolean @default(false)
  isGlutenFree   Boolean @default(false)
  isHalal        Boolean @default(false)
  isKosher       Boolean @default(false)

  // 14 EU allergens (true = CONTAINS)
  allergenGluten     Boolean @default(false)
  allergenCrustacean Boolean @default(false)
  allergenEgg        Boolean @default(false)
  allergenFish       Boolean @default(false)
  allergenPeanut     Boolean @default(false)
  allergenSoy        Boolean @default(false)
  allergenMilk       Boolean @default(false)
  allergenNuts       Boolean @default(false)  // tree nuts
  allergenCelery     Boolean @default(false)
  allergenMustard    Boolean @default(false)
  allergenSesame     Boolean @default(false)
  allergenSulphites  Boolean @default(false)
  allergenLupin      Boolean @default(false)
  allergenMollusc    Boolean @default(false)

  sortOrder Int @default(0)

  @@index([courseId, sortOrder])
}

// ── HR: Employee Documents ─────────────────────────────────────────────────────
model EmployeeDocument {
  id          String   @id @default(cuid())
  businessId  String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  title       String
  category    String   @default("OTHER") // CONTRACT | ID | CERT | HANDBOOK | TAX | OTHER
  fileUrl     String   // Vercel Blob URL
  fileName    String
  fileSize    Int?     // bytes

  uploadedById String?  // userId who uploaded

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, employeeId])
  @@index([employeeId, category])
}

// ── HR: Onboarding Tasks ──────────────────────────────────────────────────────
model OnboardingTask {
  id          String   @id @default(cuid())
  businessId  String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  title       String
  description String?
  completed   Boolean  @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, employeeId])
}

// ── Supplier Statements ────────────────────────────────────────────────────────
model SupplierStatement {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  fileUrl     String   // Vercel Blob URL
  fileName    String
  status      String   @default("pending") // pending | matched | discrepancy | accepted

  aiExtracted Json?    // raw AI-parsed line items array
  matchedOrderId String? // SupplierOrder.id if matched

  totalAmount Float?   // AI-extracted invoice total
  invoiceRef  String?  // invoice number from document

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, supplierId])
  @@index([businessId, status])
}

// ─── POS Integration ─────────────────────────────────────────────────────────

model PosConnection {
  id           String    @id @default(cuid())
  businessId   String    @unique
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  provider     String    // "lightspeed" | "square"
  accessToken  String    // AES-256-GCM encrypted
  refreshToken String?   // AES-256-GCM encrypted
  tokenExpiry  DateTime?
  locationId   String?   // Square location ID or Lightspeed businessId
  accountId    String?   // Lightspeed account ID
  connectedAt  DateTime  @default(now())
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PosSnapshot {
  id                String   @id @default(cuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date              DateTime // date only (start of day UTC)
  provider          String
  totalRevenue      Float
  totalCovers       Int      @default(0)
  totalTransactions Int      @default(0)
  hourlyData        Json?    // [{ hour: 9, revenue: 450.00, transactions: 12 }, ...]
  topItems          Json?    // [{ name: "Guinness", count: 45, revenue: 202.50 }, ...]
  rawMeta           Json?    // minimal provenance metadata, no customer PII
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([businessId, date])
  @@index([businessId, date])
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model Customer {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name          String
  email         String?
  phone         String?
  birthday      DateTime?
  dietaryNotes  String?
  allergies     String?
  tags          String[]  @default([])
  internalNotes String?

  gdprConsent   Boolean   @default(false)
  gdprConsentAt DateTime?
  isAnonymised  Boolean   @default(false)

  reservations  Reservation[]
  crmNotes      CrmNote[]
  crmEmails     CrmEmail[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([businessId])
  @@index([businessId, email])
}

model CrmNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  note       String
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model CrmEmail {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sentById   String
  sentBy     User     @relation(fields: [sentById], references: [id])
  subject    String
  preview    String
  body       String
  sentAt     DateTime @default(now())

  @@index([customerId])
}

model ReferralPartner {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  company      String?
  code         String   @unique
  commissionPct Int     @default(20)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  referrals    Referral[]
}

model Referral {
  id          String          @id @default(cuid())
  partnerId   String
  partner     ReferralPartner @relation(fields: [partnerId], references: [id])
  businessId  String?
  email       String
  status      String          @default("pending") // pending, converted, cancelled
  plan        String?
  commission  Float?
  createdAt   DateTime        @default(now())
  convertedAt DateTime?

  @@index([partnerId])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   @db.Text
  category    String   @default("hospitality")
  tags        String   @default("")
  metaTitle   String
  metaDesc    String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published, createdAt])
}

model WastageRecord {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockItemId String?
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)

  itemName    String    // free-text fallback if no stockItemId
  quantity    Float
  unit        String    @default("unit")
  unitCost    Float?    // cost per unit at time of recording
  totalCost   Float?    // quantity × unitCost
  reason      String    @default("spoilage") // spoilage | over-prep | spill | expiry | other
  notes       String?
  recordedBy  String    // userId
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([businessId, date])
  @@index([businessId, stockItemId])
}

model HACCPRecord {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  checkType   String
  checkedAt   DateTime @default(now())
  checkedById String
  checkedBy   User     @relation(fields: [checkedById], references: [id])
  data        Json
  status      String   @default("pass")
  notes       String?
  createdAt   DateTime @default(now())

  @@index([businessId, checkType])
  @@index([businessId, checkedAt])
}
