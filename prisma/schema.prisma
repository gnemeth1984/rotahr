generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                 String       @id @default(cuid())
  name               String
  onboardingComplete Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Geofencing for clock in/out
  geoLat             Float?       // premises latitude
  geoLng             Float?       // premises longitude
  geoRadius          Int          @default(200) // metres

  users        User[]
  departments  Department[]
  employees    Employee[]
  tables       Table[]
  reservations Reservation[]
  expenses     Expense[]
  menuSpecials MenuSpecial[]
  aiSettings   AISettings?
  suppliers    Supplier[]
  stockItems   StockItem[]
  supplierOrders SupplierOrder[]
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  password   String?
  role       String    @default("STAFF")
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employees           Employee[]
  passwordResetTokens PasswordResetToken[]
  appNotifications    AppNotification[]
  menuSpecials        MenuSpecial[]     @relation("MenuSpecialAuthor")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id         String   @id @default(cuid())
  name       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?
  role         String   @default("staff")
  hourlyRate   Float?
  active       Boolean  @default(true)
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts          Shift[]
  timeOffRequests TimeOffRequest[]
  expenses        Expense[]
  notifications   BookingNotification[]
  flags           BookingFlag[]
  clockEvents     ClockEvent[]
  sentMessages    Message[]              @relation("MessageSender")
  receivedMessages Message[]             @relation("MessageRecipient")
  availability    AvailabilityPreference[]
  shiftTemplates  ShiftTemplate[]
}

model Shift {
  id            String    @id @default(cuid())
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  role          String?
  published     Boolean   @default(false)
  overtimeHours Float     @default(0)
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TimeOffRequest {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending")
  reason      String?
  managedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Table {
  id         String   @id @default(cuid())
  name       String
  capacity   Int
  location   String?
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reservations Reservation[]
}

model Expense {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])

  amount        Float
  vatAmount     Float    @default(0)
  currency      String   @default("EUR")
  vendor        String?
  category      String
  date          DateTime
  description   String?
  paymentMethod String?
  status        String   @default("confirmed")

  receiptUrl      String?
  receiptDataUrl  String?   // base64 data URI — permanent fallback for 30-day recall
  receiptExpiresAt DateTime? // 30 days from upload
  aiRawText       String?

  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reservation {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  partySize     Int
  date          DateTime
  time          String
  duration      Int      @default(90)
  status        String   @default("confirmed")
  notes         String?
  dietary       String?
  occasion      String?
  kitchenNotes  String?
  upsellNotes   String?
  aiWarnings    String?
  createdById   String?
  tableId       String?
  table         Table?   @relation(fields: [tableId], references: [id])
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  notifications BookingNotification[]
  flags         BookingFlag[]
}

model BookingNotification {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  message       String?
  read          Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model BookingFlag {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  note          String
  resolved      Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

// ── Staff Messaging ────────────────────────────────────────────────────────────
model Message {
  id          String   @id @default(cuid())
  businessId  String
  senderId    String
  recipientId String
  body        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender    Employee @relation("MessageSender",    fields: [senderId],    references: [id], onDelete: Cascade)
  recipient Employee @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
}

// ── Clock In / Out ─────────────────────────────────────────────────────────────
model ClockEvent {
  id         String   @id @default(cuid())
  employeeId String
  businessId String
  type       String   // "in" | "out"
  timestamp  DateTime @default(now())
  note       String?
  shiftId    String?
  latitude   Float?   // where employee clocked in/out
  longitude  Float?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ── Staff Availability Preferences ────────────────────────────────────────────
model AvailabilityPreference {
  id         String   @id @default(cuid())
  employeeId String
  businessId String
  dayOfWeek  Int      // 0=Sun 1=Mon … 6=Sat
  available  Boolean  @default(true)
  fromTime   String?  // "09:00"
  toTime     String?  // "17:00"
  note       String?
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
}

// ── Repeating Shift Templates ──────────────────────────────────────────────────
model ShiftTemplate {
  id          String   @id @default(cuid())
  businessId  String
  employeeId  String
  dayOfWeek   Int      // 0=Sun … 6=Sat
  startHour   Int
  startMinute Int      @default(0)
  endHour     Int
  endMinute   Int      @default(0)
  role        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ── In-App Notifications ───────────────────────────────────────────────────────
model AppNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "message" | "shift" | "timeoff" | "booking" | "rota"
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// ── Menu Specials / Board ──────────────────────────────────────────────────────
model MenuSpecial {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("MenuSpecialAuthor", fields: [createdById], references: [id])

  title       String
  description String?   @db.Text
  category    String    @default("special") // "special" | "change" | "announcement" | "86'd"
  date        DateTime  // primary date / start of range
  endDate     DateTime? // optional end date for multi-day
  pinned      Boolean   @default(false)
  imageUrl    String?   // optional photo of the dish
  imageDataUri String?  @db.Text
  archived    Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([businessId, archived, date])
}

// ── AI Assistant Settings ──────────────────────────────────────────────────────
model AISettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Staffing thresholds
  bookingThresholdForStaffIncrease Int     @default(20)   // covers → suggest more staff
  kitchenRatio                     Int     @default(20)   // 1 kitchen per N covers
  floorRatio                       Int     @default(15)   // 1 floor per N covers
  minBarStaff                      Int     @default(1)

  // Rota settings
  rotaWarningDaysAhead             Int     @default(3)    // warn about short staffing X days ahead
  autoFlagShortStaffedShifts       Boolean @default(true)
  minStaffPerShift                 Int     @default(2)

  // Specials / price change communication
  priceChangeNotifyScope           String  @default("managers") // "managers" | "all_staff" | "none"
  priceChangeMessage               String? @db.Text             // custom message template

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Stock Management ───────────────────────────────────────────────────────────
model Supplier {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?  @db.Text
  active      Boolean  @default(true)

  stockItems  StockItem[]
  orders      SupplierOrder[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, active])
}

model StockItem {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])

  name         String
  sku          String?          // supplier's product code
  unit         String           @default("unit") // "unit", "kg", "litre", "case", "box", "bottle" etc
  category     String           @default("general") // "food", "beverage", "cleaning", "packaging", "equipment", "other"

  lastPrice    Float?           // price from most recent receipt/invoice
  lastOrdered  DateTime?        // date of last order
  reorderLevel Float?           // trigger reorder below this qty
  currentStock Float?           // optional manual stock count
  notes        String?          @db.Text

  // Source tracing
  lastExpenseId String?         // which expense/receipt last updated this item

  orderItems   OrderItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId, supplierId])
  @@index([businessId, category])
}

model SupplierOrder {
  id          String      @id @default(cuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier    @relation(fields: [supplierId], references: [id])

  status      String      @default("draft")   // "draft" | "sent" | "received"
  notes       String?     @db.Text
  sentAt      DateTime?
  receivedAt  DateTime?

  items       OrderItem[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([businessId, supplierId, status])
}

model OrderItem {
  id          String        @id @default(cuid())
  orderId     String
  order       SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem     @relation(fields: [stockItemId], references: [id])

  quantity    Float
  unitPrice   Float?
  notes       String?

  @@index([orderId])
}
