generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                 String       @id @default(cuid())
  name               String
  onboardingComplete Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Geofencing for clock in/out
  geoLat             Float?       // premises latitude
  geoLng             Float?       // premises longitude
  geoRadius          Int          @default(200) // metres

  users        User[]
  departments  Department[]
  employees    Employee[]
  tables       Table[]
  reservations Reservation[]
  expenses     Expense[]
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  password   String?
  role       String    @default("STAFF")
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employees           Employee[]
  passwordResetTokens PasswordResetToken[]
  appNotifications    AppNotification[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id         String   @id @default(cuid())
  name       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?
  ppsNumber    String?
  role         String   @default("staff")
  hourlyRate   Float?
  active       Boolean  @default(true)
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])

  // Emergency contact
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?

  // Medical info
  medicalConditions String?
  medications       String?
  bloodType         String?
  doctorName        String?
  doctorPhone       String?
  medicalNotes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts          Shift[]
  timeOffRequests TimeOffRequest[]
  expenses        Expense[]
  notifications   BookingNotification[]
  flags           BookingFlag[]
  clockEvents     ClockEvent[]
  sentMessages    Message[]              @relation("MessageSender")
  receivedMessages Message[]             @relation("MessageRecipient")
  availability    AvailabilityPreference[]
  shiftTemplates  ShiftTemplate[]
}

model Shift {
  id            String    @id @default(cuid())
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  role          String?
  published     Boolean   @default(false)
  overtimeHours Float     @default(0)
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TimeOffRequest {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending")
  reason      String?
  managedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Table {
  id         String   @id @default(cuid())
  name       String
  capacity   Int
  location   String?
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reservations Reservation[]
}

model Expense {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])

  amount        Float
  vatAmount     Float    @default(0)
  currency      String   @default("EUR")
  vendor        String?
  category      String
  date          DateTime
  description   String?
  paymentMethod String?
  status        String   @default("confirmed")

  receiptUrl      String?
  receiptDataUrl  String?   // base64 data URI — permanent fallback for 30-day recall
  receiptExpiresAt DateTime? // 30 days from upload
  aiRawText       String?

  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reservation {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  partySize     Int
  date          DateTime
  time          String
  duration      Int      @default(90)
  status        String   @default("confirmed")
  notes         String?
  dietary       String?
  occasion      String?
  kitchenNotes  String?
  upsellNotes   String?
  aiWarnings    String?
  createdById   String?
  tableId       String?
  table         Table?   @relation(fields: [tableId], references: [id])
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  notifications BookingNotification[]
  flags         BookingFlag[]
}

model BookingNotification {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  message       String?
  read          Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model BookingFlag {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  note          String
  resolved      Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

// ── Staff Messaging ────────────────────────────────────────────────────────────
model Message {
  id          String   @id @default(cuid())
  businessId  String
  senderId    String
  recipientId String
  body        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender    Employee @relation("MessageSender",    fields: [senderId],    references: [id], onDelete: Cascade)
  recipient Employee @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
}

// ── Clock In / Out ─────────────────────────────────────────────────────────────
model ClockEvent {
  id         String   @id @default(cuid())
  employeeId String
  businessId String
  type       String   // "in" | "out"
  timestamp  DateTime @default(now())
  note       String?
  shiftId    String?
  latitude   Float?   // where employee clocked in/out
  longitude  Float?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ── Staff Availability Preferences ────────────────────────────────────────────
model AvailabilityPreference {
  id         String   @id @default(cuid())
  employeeId String
  businessId String
  dayOfWeek  Int      // 0=Sun 1=Mon … 6=Sat
  available  Boolean  @default(true)
  fromTime   String?  // "09:00"
  toTime     String?  // "17:00"
  note       String?
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
}

// ── Repeating Shift Templates ──────────────────────────────────────────────────
model ShiftTemplate {
  id          String   @id @default(cuid())
  businessId  String
  employeeId  String
  dayOfWeek   Int      // 0=Sun … 6=Sat
  startHour   Int
  startMinute Int      @default(0)
  endHour     Int
  endMinute   Int      @default(0)
  role        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ── In-App Notifications ───────────────────────────────────────────────────────
model AppNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "message" | "shift" | "timeoff" | "booking" | "rota"
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}
